// Init control knobs
makeCtrlKnob('knob-bpm','knob-bpm-wrap',{min:60,max:220,def:110,color:'#e8401a',label:'BPM',onChange:v=>{bpm=v;document.getElementById('bpm-num').textContent=v;if(playing)lcd('PLAY  BPM:'+v);}});
makeCtrlKnob('knob-vol','knob-vol-wrap',{min:0,max:100,def:80,color:'#3a9a3a',label:'VOL',onChange:v=>{if(MG)MG.gain.value=v/100;}});
makeCtrlKnob('knob-sw','knob-sw-wrap',{min:0,max:50,def:0,color:'#c9900a',label:'SW',onChange:v=>{swingVal=v;}});
</script>
