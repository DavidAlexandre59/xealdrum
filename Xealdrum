// ═══════════════════════════════════════════════════════
//  SEQUENCER LOOP
// ═══════════════════════════════════════════════════════
function tick(){
  if(curStep>=0) DRUMS.forEach(d=>{const b=document.getElementById('sb-'+d.id+'-'+curStep);if(b)b.classList.remove('cur');});
  curStep=(curStep+1)%STEPS;
  DRUMS.forEach(d=>{const b=document.getElementById('sb-'+d.id+'-'+curStep);if(b)b.classList.add('cur');});
  DRUMS.forEach(drum=>{if(!muteState[drum.id]&&pat[drum.id][curStep]){playDrum(drum.id);flashPad(drum.id);}});
  const ms=(60/bpm/4)*1000;
  const swoff=(curStep%2===1)?ms*swingVal*.01*.33:0;
  ticker=setTimeout(tick,ms+swoff);
}

function togglePlay(){
  getAC();
  if(playing){
    clearTimeout(ticker);playing=false;
    if(recMode){recMode=false;updateRecUI();}
    curStep=-1;
    DRUMS.forEach(d=>{for(let s=0;s<STEPS;s++){const b=document.getElementById('sb-'+d.id+'-'+s);if(b)b.classList.remove('cur');}});
    document.getElementById('btn-play').textContent='▶ PLAY';
    document.getElementById('btn-play').classList.remove('pon');
    lcd('XEAL-DRUM  READY');
  } else {
    playing=true;curStep=-1;
    document.getElementById('btn-play').textContent='■ STOP';
    document.getElementById('btn-play').classList.add('pon');
    lcd('PLAY  BPM:'+bpm);
    tick();
  }
}

// ═══════════════════════════════════════════════════════
//  REC / OVERDUB
// ═══════════════════════════════════════════════════════
function toggleRec(){
  if(!playing){recMode=true;updateRecUI();togglePlay();return;}
  recMode=!recMode;updateRecUI();
}
function updateRecUI(){
  document.getElementById('btn-rec').className='btn'+(recMode?' ron':'');
  document.getElementById('rec-dot').className=recMode?'show':'';
  lcd(recMode?'REC+PLAY  OVERDUB':playing?'PLAY  BPM:'+bpm:'XEAL-DRUM  READY');
}

function hitPad(drum){
  getAC();playDrum(drum.id);
  if(recMode&&playing&&curStep>=0){
    if(!pat[drum.id][curStep]){pat[drum.id][curStep]=true;drawBtn(drum.id,curStep);}
  }
  flashPad(drum.id,true);
  lcd(drum.label);
  setTimeout(()=>lcd(recMode?'REC+PLAY  OVERDUB':playing?'PLAY  BPM:'+bpm:'XEAL-DRUM  READY'),400);
}

function flashPad(id,long=false){
  const pad=document.getElementById('pd-'+id);if(!pad)return;
  const drum=DRUMS.find(d=>d.id===id);
  pad.classList.add('hit');pad.style.borderColor=drum.color;
  pad.style.background=`linear-gradient(160deg,${drum.color}cc,${drum.color}88)`;
  pad.querySelector('.pled').style.cssText=`background:#fff;box-shadow:0 0 10px ${drum.color}`;
  pad.querySelector('.plbl').style.color='#fff';
  setTimeout(()=>{
    pad.classList.remove('hit');pad.style.borderColor='';pad.style.background='';
    pad.querySelector('.pled').style.cssText=`background:${drum.color}40;`;
    pad.querySelector('.plbl').style.color='';
  },long?150:70);
}

// ═══════════════════════════════════════════════════════
//  MACHINE — theme background per machine
// ═══════════════════════════════════════════════════════
function loadMachine(id){
  activeMachine=id;
  const bank=BANKS[id];if(!bank)return;
  document.getElementById('fmach').textContent=bank.label;
  // Update CSS vars for machine theme
  const root=document.documentElement.style;
  root.setProperty('--machine-a',bank.accent||'#e8401a');
  document.body.style.background=bank.bg||'#0d0d0d';
  // Update sequencer bg to be slightly lighter than body
  const seqEl=document.getElementById('seq');if(seqEl)seqEl.style.background=bank.bg?bank.bg+'99':'#080808';
  lcd(bank.label.substring(0,20).toUpperCase());
  setTimeout(()=>lcd(playing?'PLAY  BPM:'+bpm:'XEAL-DRUM  READY'),1200);
}

// ═══════════════════════════════════════════════════════
//  GROOVE & STEPS
// ═══════════════════════════════════════════════════════
function toggleStep(id,s){pat[id][s]=!pat[id][s];drawBtn(id,s);}

function clearPat(){
  clearTimeout(ticker);playing=false;recMode=false;curStep=-1;
  DRUMS.forEach(d=>{for(let s=0;s<MAX_STEPS;s++){const b=document.getElementById('sb-'+d.id+'-'+s);if(b)b.classList.remove('cur');}});
  document.getElementById('btn-play').textContent='▶ PLAY';
  document.getElementById('btn-play').classList.remove('pon');
  updateRecUI();
  DRUMS.forEach(d=>pat[d.id]=new Array(MAX_STEPS).fill(false));
  renderAll();
  lcd('CLEARED');setTimeout(()=>lcd('XEAL-DRUM  READY'),700);
}

function loadGroove(){
  const v=document.getElementById('grv-sel').value;
  let fn=GROOVES[v];
  if(!fn&&userGrooves[v]){
    // load user groove
    const saved=userGrooves[v];
    pat=JSON.parse(JSON.stringify(saved.pat));
    if(saved.steps){STEPS=saved.steps;document.getElementById('steps-sel').value=STEPS;applySteps();}
    renderAll();
    lcd(v.substring(0,20));setTimeout(()=>lcd(playing?'PLAY  BPM:'+bpm:'XEAL-DRUM  READY'),1000);
    return;
  }
  if(!fn)return;
  pat=fn();renderAll();
  lcd(v);setTimeout(()=>lcd(playing?'PLAY  BPM:'+bpm:'XEAL-DRUM  READY'),1000);
}

function setSteps(n){
  const oldSteps=STEPS;
  STEPS=n;
  if(curStep>=STEPS){
    DRUMS.forEach(d=>{const b=document.getElementById('sb-'+d.id+'-'+curStep);if(b)b.classList.remove('cur');});
    curStep=-1;
  }
  // Only rescale if pattern has NO content beyond step 15 (user-made short pattern)
  // Groove patterns are already tiled to MAX_STEPS — no rescaling needed
  const hasContentBeyond16=DRUMS.some(d=>d.id&&pat[d.id]&&pat[d.id].slice(16).some(v=>v));
  if(!hasContentBeyond16 && oldSteps<=16 && n>16){
    // Tile the existing 16-step content into the new longer range
    DRUMS.forEach(d=>{
      for(let i=16;i<n;i++) pat[d.id][i]=pat[d.id][i%16];
    });
  } else if(!hasContentBeyond16 && n<=16 && oldSteps<=16 && oldSteps!==n){
    // Rescale within 16 steps
    const newPat={};
    DRUMS.forEach(d=>{newPat[d.id]=scalePattern(pat[d.id],n);});
    pat=newPat;
  }
  applySteps();
  renderAll();
  lcd('MESURE: '+n+' PAS');
  setTimeout(()=>lcd(playing?'PLAY  BPM:'+bpm:'XEAL-DRUM  READY'),900);
}

// ═══════════════════════════════════════════════════════
//  SAVE / LOAD USER GROOVES
// ═══════════════════════════════════════════════════════
function openSave(){
  document.getElementById('save-modal').classList.add('show');
  document.getElementById('save-name').focus();
}
function closeSave(){document.getElementById('save-modal').classList.remove('show');}

function doSave(){
  const name=document.getElementById('save-name').value.trim();
  if(!name){lcd('NOM REQUIS!');setTimeout(()=>lcd('XEAL-DRUM  READY'),800);return;}
  const key='USER:'+name;
  userGrooves[key]={pat:JSON.parse(JSON.stringify(pat)),steps:STEPS};
  saveUserGrooves();
  // Add to dropdown if not already there
  const grpEl=document.getElementById('user-grv-group');
  if(!document.querySelector(option[value="${CSS.escape(key)}"])){
    const opt=document.createElement('option');opt.value=key;opt.textContent=name;grpEl.appendChild(opt);
  }
  document.getElementById('grv-sel').value=key;
  closeSave();
  lcd('SAVED: '+name.substring(0,14));
  setTimeout(()=>lcd(playing?'PLAY  BPM:'+bpm:'XEAL-DRUM  READY'),1200);
}

function loadUserGroovesIntoMenu(){
  const grp=document.getElementById('user-grv-group');
  Object.keys(userGrooves).forEach(key=>{
    const name=key.replace('USER:','');
    const opt=document.createElement('option');opt.value=key;opt.textContent=name;grp.appendChild(opt);
  });
}

function setBpm(v){bpm=parseInt(v);document.getElementById('bpm-num').textContent=bpm;if(playing)lcd('PLAY  BPM:'+bpm);}
function setVol(v){if(MG)MG.gain.value=v/100;}
function getSwing(){return swingVal;}

// ── Canvas knobs for TEMPO / VOLUME / SWING ──
let swingVal=0;
function makeCtrlKnob(canvasId,wrapId,opts){
  const cv=document.getElementById(canvasId);
  if(!cv)return;
  const wrap=document.getElementById(wrapId);
  const {min,max,def,color,onChange,label}=opts;
  let val=def,dragging=false,dragStartY=0,dragStartVal=0;
  const size=52;

  function draw(v){
    const ctx=cv.getContext('2d');
    const cx=size/2,cy=size/2,r=size/2-2;
    ctx.clearRect(0,0,size,size);
    // Outer chrome ring
    const outerGrad=ctx.createRadialGradient(cx-r*.3,cy-r*.3,r*.05,cx,cy,r);
    outerGrad.addColorStop(0,'#666');outerGrad.addColorStop(.45,'#222');outerGrad.addColorStop(1,'#111');
    ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.fillStyle=outerGrad;ctx.fill();
    // Knurled grip
    for(let i=0;i<24;i++){
      const a=i*(Math.PI*2/24),ri=r*.76,ro=r*.92;
      ctx.beginPath();ctx.moveTo(cx+Math.cos(a)*ri,cy+Math.sin(a)*ri);
      ctx.lineTo(cx+Math.cos(a)*ro,cy+Math.sin(a)*ro);
      ctx.strokeStyle='rgba(255,255,255,0.06)';ctx.lineWidth=1.5;ctx.stroke();
    }
    // Cap dome
    const capGrad=ctx.createRadialGradient(cx-r*.22,cy-r*.24,r*.06,cx,cy,r*.68);
    capGrad.addColorStop(0,'#4e4e4e');capGrad.addColorStop(.5,'#1e1e1e');capGrad.addColorStop(1,'#0c0c0c');
    ctx.beginPath();ctx.arc(cx,cy,r*.7,0,Math.PI*2);ctx.fillStyle=capGrad;ctx.fill();
    // Specular
    ctx.beginPath();ctx.arc(cx-r*.2,cy-r*.22,r*.16,0,Math.PI*2);
    ctx.fillStyle='rgba(255,255,255,0.08)';ctx.fill();
    // Arc track
    const minA=Math.PI*.75,maxA=Math.PI*2.25;
    ctx.beginPath();ctx.arc(cx,cy,r*.82,minA,maxA);
    ctx.strokeStyle='#2a2a2a';ctx.lineWidth=3;ctx.stroke();
    // Value arc
    const norm=(v-min)/(max-min);
    const valA=minA+norm*(maxA-minA);
    ctx.beginPath();ctx.arc(cx,cy,r*.82,minA,valA);
    ctx.strokeStyle=color;ctx.lineWidth=3;ctx.stroke();
    // Indicator line
    ctx.beginPath();
    ctx.moveTo(cx+Math.cos(valA)*r*.35,cy+Math.sin(valA)*r*.35);
    ctx.lineTo(cx+Math.cos(valA)*r*.66,cy+Math.sin(valA)*r*.66);
    ctx.strokeStyle='#fff';ctx.lineWidth=2.5;ctx.lineCap='round';ctx.stroke();
  }

  function setVal(v){
    val=Math.max(min,Math.min(max,Math.round(v)));
    draw(val);onChange(val);
  }

  wrap.addEventListener('mousedown',e=>{dragging=true;dragStartY=e.clientY;dragStartVal=val;e.preventDefault();});
  window.addEventListener('mousemove',e=>{if(!dragging)return;const dy=dragStartY-e.clientY;const range=max-min;setVal(dragStartVal+Math.round(dy*(range/120)));});
  window.addEventListener('mouseup',()=>dragging=false);
  wrap.addEventListener('touchstart',e=>{dragging=true;dragStartY=e.touches[0].clientY;dragStartVal=val;e.preventDefault();},{passive:false});
  wrap.addEventListener('touchmove',e=>{if(!dragging)return;const dy=dragStartY-e.touches[0].clientY;const range=max-min;setVal(dragStartVal+Math.round(dy*(range/120)));e.preventDefault();},{passive:false});
  wrap.addEventListener('touchend',()=>dragging=false);
  wrap.addEventListener('dblclick',()=>setVal(def));
  draw(def);
}
function lcd(msg){document.getElementById('lcd-text').textContent=(msg||'').substring(0,20);}

// ═══════════════════════════════════════════════════════
//  KEYBOARD
// ═══════════════════════════════════════════════════════
document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT')return;
  if(e.code==='Space'){e.preventDefault();togglePlay();}
  if(e.code==='KeyR'&&!e.ctrlKey&&!e.metaKey){toggleRec();}
  if(e.code==='Escape'){closeSave();}
});
document.getElementById('save-name').addEventListener('keydown',e=>{if(e.code==='Enter')doSave();if(e.code==='Escape')closeSave();});

