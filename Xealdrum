<script>
'use strict';
// ═══════════════════════════════════════════════════════
//  AUDIO CORE
// ═══════════════════════════════════════════════════════
let AC=null, MG=null, analyser=null;

function getAC(){
  if(!AC){
    AC=new(window.AudioContext||window.webkitAudioContext)();
    MG=AC.createGain(); MG.gain.value=0.8;
    analyser=AC.createAnalyser(); analyser.fftSize=256;
    MG.connect(analyser); analyser.connect(AC.destination);
  }
  if(AC.state==='suspended') AC.resume();
  return AC;
}
function G(){getAC();return MG;}

function mkNs(dur){
  const ctx=AC,sz=Math.ceil(ctx.sampleRate*dur),buf=ctx.createBuffer(1,sz,ctx.sampleRate),d=buf.getChannelData(0);
  for(let i=0;i<sz;i++) d[i]=Math.random()*2-1;
  const s=ctx.createBufferSource();s.buffer=buf;return s;
}
function cn(...n){for(let i=0;i<n.length-1;i++) n[i].connect(n[i+1]);}
function ev(g,pk,dc,t){g.gain.setValueAtTime(pk,t);g.gain.exponentialRampToValueAtTime(.0001,t+dc);}
function mkOsc(type='sine'){const o=AC.createOscillator();o.type=type;return o;}
function mkGain(){return AC.createGain();}
function mkBPF(f,q){const b=AC.createBiquadFilter();b.type='bandpass';b.frequency.value=f;b.Q.value=q||.7;return b;}
function mkHPF(f){const b=AC.createBiquadFilter();b.type='highpass';b.frequency.value=f;return b;}

// pitch multipliers per drum (default 1.0, range .25 to 4.0)
const pitchMult={};

function pf(id){ return pitchMult[id]||1; }

// ═══════════════════════════════════════════════════════
//  SOUND PRIMITIVES (pitch-aware)
// ═══════════════════════════════════════════════════════
function kickSub(t,f0,f1,dec,vol,pid){
  const p=pf(pid||'kick'),out=G(),o=mkOsc(),g=mkGain();cn(o,g,out);
  o.frequency.setValueAtTime(f0*p,t);o.frequency.exponentialRampToValueAtTime(f1*p,t+dec*.5);
  ev(g,vol||1.3,dec,t);o.start(t);o.stop(t+dec+.02);
}
function kickClick(t,freq,dec,pid){
  const p=pf(pid||'kick'),out=G(),o=mkOsc(),g=mkGain();cn(o,g,out);
  o.frequency.value=freq*p;ev(g,.6,dec,t);o.start(t);o.stop(t+dec+.005);
}
function kickNoise(t,dec){const out=G(),ns=mkNs(dec+.01),g=mkGain();cn(ns,g,out);ev(g,1.0,dec,t);ns.start(t);ns.stop(t+dec+.01);}
function kickDistort(t,f0,f1,dec,pid){
  const p=pf(pid||'kick'),ctx=AC,out=G(),o=mkOsc(),dist=ctx.createWaveShaper(),g=mkGain();
  const curve=new Float32Array(256);for(let i=0;i<256;i++)curve[i]=Math.tanh((i/128-1)*4);
  dist.curve=curve;cn(o,dist,g,out);
  o.frequency.setValueAtTime(f0*p,t);o.frequency.exponentialRampToValueAtTime(f1*p,t+dec*.5);
  ev(g,1.5,dec,t);o.start(t);o.stop(t+dec+.02);
}
function snareNoiseTone(t,bpF,bpQ,tF0,tF1,tDec,nsDec,vol,pid){
  const p=pf(pid||'snare'),out=G(),ns=mkNs(nsDec+.02),f=mkBPF(bpF*p,bpQ),g=mkGain();
  cn(ns,f,g,out);ev(g,vol||.9,nsDec,t);ns.start(t);ns.stop(t+nsDec+.02);
  if(tF0){const o=mkOsc(),og=mkGain();cn(o,og,out);o.frequency.setValueAtTime(tF0*p,t);o.frequency.exponentialRampToValueAtTime(tF1*p,t+tDec*.6);ev(og,.5,tDec,t);o.start(t);o.stop(t+tDec+.01);}
}
function snareSaw(t,f0,f1,dec,pid){
  const p=pf(pid||'snare'),out=G(),o=mkOsc('sawtooth'),g=mkGain();cn(o,g,out);
  o.frequency.setValueAtTime(f0*p,t);o.frequency.exponentialRampToValueAtTime(f1*p,t+dec*.6);
  ev(g,.7,dec,t);o.start(t);o.stop(t+dec+.01);
  const ns=mkNs(dec),nf=mkBPF(3000*p,.5),ng=mkGain();cn(ns,nf,ng,out);ev(ng,.4,dec*.8,t);ns.start(t);ns.stop(t+dec+.01);
}
function hhMetal(t,base,dec,hp,pid){
  const p=pf(pid||'hhc'),out=G();
  [1,1.342,1.232,1.633,1.983,2.001].forEach(r=>{
    const o=mkOsc('square'),hpf=mkHPF(hp*p),g=mkGain();o.frequency.value=base*r*p;cn(o,hpf,g,out);ev(g,.042,dec,t);o.start(t);o.stop(t+dec+.01);
  });
}
function hhNoise(t,dec,hpF,pid){
  const p=pf(pid||'hhc'),out=G(),ns=mkNs(dec+.01),f=mkHPF(hpF*p),g=mkGain();
  cn(ns,f,g,out);ev(g,.7,dec,t);ns.start(t);ns.stop(t+dec+.01);
}
function clapFn(t,bpF,sp,dec,cnt,pid){
  const p=pf(pid||'clap'),out=G();
  for(let i=0;i<(cnt||3);i++){const ti=t+i*sp,ns=mkNs(dec+.01),f=mkBPF(bpF*p,.5),g=mkGain();cn(ns,f,g,out);ev(g,.88,dec,ti);ns.start(ti);ns.stop(ti+dec+.01);}
}
function rimShot(t,freq,dec,pid){
  const p=pf(pid||'rim'),out=G(),o=mkOsc('square'),g=mkGain();o.frequency.value=freq*p;cn(o,g,out);ev(g,.5,dec,t);o.start(t);o.stop(t+dec+.01);
  const ns=mkNs(dec+.01),ng=mkGain();cn(ns,ng,out);ev(ng,.32,dec,t);ns.start(t);ns.stop(t+dec+.01);
}
function tomTone(t,f0,f1,dec,pid){
  const p=pf(pid||'tomhi'),out=G(),o=mkOsc(),g=mkGain();cn(o,g,out);
  o.frequency.setValueAtTime(f0*p,t);o.frequency.exponentialRampToValueAtTime(f1*p,t+dec*.6);
  ev(g,1.0,dec,t);o.start(t);o.stop(t+dec+.01);
}
function cowbellFn(t,f1,f2,dec,pid){
  const p=pf(pid||'guiro'),out=G();
  [f1,f2].forEach(fr=>{const o=mkOsc('square'),g=mkGain();o.frequency.value=fr*p;cn(o,g,out);ev(g,.25,dec,t);o.start(t);o.stop(t+dec+.01);});
}
function guiroFn(t,pid){
  // Guiro: scraped gourd — noise burst with falling pitch modulation
  const ctx=AC,p=pf(pid||'guiro'),out=G();
  const ns=mkNs(.12),bpf1=mkBPF(1200*p,.4),g=mkGain();
  cn(ns,bpf1,g,out);ev(g,.6,.11,t);ns.start(t);ns.stop(t+.13);
  // pitched scrape tone
  const o=mkOsc('sawtooth'),og=mkGain();o.frequency.setValueAtTime(800*p,t);
  o.frequency.exponentialRampToValueAtTime(200*p,t+.1);
  cn(o,og,out);ev(og,.12,.1,t);o.start(t);o.stop(t+.11);
}
function quijadaFn(t,pid){
  // Quijada (jawbone/vibraslap): sharp rattle — burst of fast noise + resonance
  const ctx=AC,p=pf(pid||'quijada'),out=G();
  const ns=mkNs(.15),g=mkGain();cn(ns,g,out);
  // fast attack envelope with rattle-like decay
  g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(.9,t+.003);
  g.gain.exponentialRampToValueAtTime(.0001,t+.14);
  ns.start(t);ns.stop(t+.15);
  // resonant body
  const o=mkOsc('triangle'),og=mkGain();o.frequency.setValueAtTime(1100*p,t);
  o.frequency.exponentialRampToValueAtTime(300*p,t+.08);
  cn(o,og,out);ev(og,.35,.07,t);o.start(t);o.stop(t+.09);
  // high frequency shimmer
  const ns2=mkNs(.06),f2=mkBPF(4000*p,1.5),g2=mkGain();cn(ns2,f2,g2,out);
  ev(g2,.4,.05,t);ns2.start(t);ns2.stop(t+.06);
}
function cymNoise(t,dec,hp,pid){hhNoise(t,dec,hp,pid||'cym');}

