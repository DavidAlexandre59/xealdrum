const VU_BARS=14;
let vuRafId=null, vuData=null;

function buildVU(){
  const wrap=document.getElementById('vu-wrap');
  for(let i=0;i<VU_BARS;i++){
    const b=document.createElement('div');b.className='vub';
    b.style.height='20px';
    const fill=document.createElement('div');fill.className='vub-fill';
    // color gradient: green → yellow → red
    const ratio=i/(VU_BARS-1);
    const r=Math.round(ratio<.5?ratio*2*100:100);
    const g=Math.round(ratio<.5?100:(1-ratio)*2*100);
    fill.style.background=`rgb(${r}%,${g}%,0%)`;
    b.appendChild(fill);
    wrap.appendChild(b);
  }
}


// ── VU needle state ──
let _vL=0,_vR=0,_pL=0,_pR=0,_hL=0,_hR=0;
const _VD=0.92,_VA=0.55,_VH=55;

function _vu(id,lv,pk,lb){
  const cv=document.getElementById(id);
  if(!cv||!cv.offsetWidth)return;
  const W=cv.offsetWidth,H=cv.offsetHeight;
  cv.width=W;cv.height=H;
  const c=cv.getContext('2d');
  c.clearRect(0,0,W,H);
  const bg=c.createLinearGradient(0,0,0,H);
  bg.addColorStop(0,'#1a1810');bg.addColorStop(1,'#0e0d08');
  c.fillStyle=bg;c.beginPath();
  if(c.roundRect)c.roundRect(0,0,W,H,3);else c.rect(0,0,W,H);
  c.fill();
  const cx=W/2,cy=H*1.06,R=H*.98;
  const sA=-Math.PI*.72,eA=-Math.PI*.28,tA=eA-sA;
  // ticks
  [[0,'−20'],[.22,'−10'],[.5,'−5'],[.82,'0'],[1,'+3']].forEach(([v,t])=>{
    const a=sA+v*tA;
    c.beginPath();c.moveTo(cx+Math.cos(a)*R*.78,cy+Math.sin(a)*R*.78);
    c.lineTo(cx+Math.cos(a)*R*.9,cy+Math.sin(a)*R*.9);
    c.strokeStyle=v>=.82?'#883300':'#443322';c.lineWidth=1.2;c.stroke();
    c.fillStyle=v>=.82?'#993311':'#443322';
    c.font=`bold ${Math.max(5,W*.068)}px Courier New`;
    c.textAlign='center';c.textBaseline='middle';
    c.fillText(t,cx+Math.cos(a)*R*.66,cy+Math.sin(a)*R*.66);
  });
  // arcs
  const aR=R*.84,g0=sA+.82*tA,g1=sA+.94*tA;
  c.lineWidth=3;
  c.beginPath();c.arc(cx,cy,aR,sA,g0);c.strokeStyle='#1a4a1a';c.stroke();
  c.beginPath();c.arc(cx,cy,aR,g0,g1);c.strokeStyle='#4a3a00';c.stroke();
  c.beginPath();c.arc(cx,cy,aR,g1,eA);c.strokeStyle='#5a1000';c.stroke();
  if(lv>0.001){
    const lA=sA+Math.min(lv,1)*tA;
    c.beginPath();c.arc(cx,cy,aR,sA,Math.min(lA,g0));c.strokeStyle='#22dd22';c.lineWidth=3;c.stroke();
    if(lv>.82){c.beginPath();c.arc(cx,cy,aR,g0,Math.min(lA,g1));c.strokeStyle='#ddcc00';c.lineWidth=3;c.stroke();}
    if(lv>.94){c.beginPath();c.arc(cx,cy,aR,g1,Math.min(lA,eA));c.strokeStyle='#ff2200';c.lineWidth=3;c.stroke();}
  }
  if(pk>.01){
    const pa=sA+Math.min(pk,1)*tA;
    c.beginPath();c.arc(cx+Math.cos(pa)*aR,cy+Math.sin(pa)*aR,2.4,0,Math.PI*2);
    c.fillStyle=pk>.82?'#ff4400':'#ffff00';c.fill();
  }
  const pR=W*.065;
  const pG=c.createRadialGradient(cx-pR*.3,cy-pR*.3,1,cx,cy,pR);
  pG.addColorStop(0,'#666');pG.addColorStop(1,'#111');
  c.beginPath();c.arc(cx,cy,pR,0,Math.PI*2);c.fillStyle=pG;c.fill();
  const nA=sA+Math.min(lv,1)*tA;
  c.beginPath();
  c.moveTo(cx+Math.cos(nA+Math.PI)*pR*.65,cy+Math.sin(nA+Math.PI)*pR*.65);
  c.lineTo(cx+Math.cos(nA)*R*.92,cy+Math.sin(nA)*R*.92);
  c.strokeStyle=lv>.82?'#ff3300':lv>.5?'#e8c010':'#dd2200';
  c.lineWidth=1.6;c.lineCap='round';c.stroke();
  c.beginPath();c.arc(cx,cy,pR*.52,0,Math.PI*2);c.fillStyle='#3a3a3a';c.fill();
  c.fillStyle='#554433';
  c.font=`bold ${Math.max(6,W*.08)}px Courier New`;
  c.textAlign='center';c.textBaseline='middle';
  c.fillText(lb,W/2,H*.11);
}

function vuFrame(){
  if(!analyser){vuRafId=requestAnimationFrame(vuFrame);return;}
  if(!vuData)vuData=new Uint8Array(analyser.frequencyBinCount);
  analyser.getByteFrequencyData(vuData);
  // bar VU
  const bands=VU_BARS;
  document.querySelectorAll('.vub-fill').forEach((fill,bi)=>{
    const lo=Math.floor(bi*vuData.length/bands);
    const hi=Math.floor((bi+1)*vuData.length/bands);
    let bs=0;for(let j=lo;j<hi;j++)bs+=vuData[j];
    const bv=(hi>lo)?bs/(hi-lo)/255:0;
    fill.style.height=(bv*100)+'%';fill.style.opacity=playing?.9:.2;
  });
  // needle VU
  const half=Math.floor(vuData.length/2);
  let sL=0;for(let i=0;i<half;i++)sL+=vuData[i]*vuData[i];
  const rL=Math.sqrt(sL/half)/255;
  let sR=0;for(let i=half;i<vuData.length;i++)sR+=vuData[i]*vuData[i];
  const rR=Math.sqrt(sR/(vuData.length-half))/255;
  _vL=rL>_vL?_vL+(rL-_vL)*_VA:_vL*_VD;
  _vR=rR>_vR?_vR+(rR-_vR)*_VA:_vR*_VD;
  if(_vL>=_pL){_pL=_vL;_hL=_VH;}else if(--_hL<=0)_pL*=.96;
  if(_vR>=_pR){_pR=_vR;_hR=_VH;}else if(--_hR<=0)_pR*=.96;
  _vu('vu-l',Math.min(1,_vL*.95),Math.min(1,_pL*.95),'L');
  _vu('vu-r',Math.min(1,_vR*1.1),Math.min(1,_pR*1.1),'R');
  vuRafId=requestAnimationFrame(vuFrame);
}

// ═══════════════════════════════════════════════════════
//  UI BUILDER
// ═══════════════════════════════════════════════════════
function buildUI(){
  // Seq header
  const hdr=document.getElementById('seq-hdr');
  // Spacer to align with dlbl
  const sp=document.createElement('div');sp.className='shdr-spacer';sp.id='shdr-sp';
  hdr.appendChild(sp);
  for(let i=0;i<MAX_STEPS;i++){
    const d=document.createElement('div');d.className='sn'+(i%4===0?' b':'');
    d.id='sh'+i;d.textContent=i%4===0?(i/4+1):'·';hdr.appendChild(d);
  }
  // Seq rows — with mute button in label
  const rows=document.getElementById('seq-rows');
  DRUMS.forEach(drum=>{
    const row=document.createElement('div');row.className='drow';row.id='row-'+drum.id;

    // Label + mute button
    const lbl=document.createElement('div');lbl.className='dlbl';lbl.style.width='clamp(54px,6.5vw,84px)';
    const nameEl=document.createElement('span');nameEl.className='dlbl-name';nameEl.textContent=drum.label;
    const muteBtn=document.createElement('button');muteBtn.className='mute-btn';muteBtn.id='mute-'+drum.id;
    muteBtn.title='Mute '+drum.label;
    muteBtn.onclick=(e)=>{e.stopPropagation();toggleMute(drum.id);};
    lbl.appendChild(nameEl);lbl.appendChild(muteBtn);
    row.appendChild(lbl);

    for(let s=0;s<MAX_STEPS;s++){
      const b=document.createElement('button');b.className='sb';b.id='sb-'+drum.id+'-'+s;
      b.dataset.d=drum.id;b.dataset.s=s;b.onclick=()=>toggleStep(drum.id,s);row.appendChild(b);
    }
    rows.appendChild(row);
  });

  // Guitar knobs for pitch
  const pr=document.getElementById('pitch-row');
  DRUMS.forEach(drum=>{
    const cell=document.createElement('div');cell.className='pcell';
    const size=Math.max(24, Math.min(44, Math.round(window.innerWidth/DRUMS.length*.8)));
    const wrap=document.createElement('div');wrap.className='pcell-knob-wrap';
    const cv=document.createElement('canvas');cv.className='knob-canvas';
    cv.width=size;cv.height=size;cv.id='knob-'+drum.id;
    wrap.appendChild(cv);

    const valEl=document.createElement('div');valEl.className='pval';valEl.id='pv-'+drum.id;valEl.textContent='0';
    const lbl=document.createElement('div');lbl.className='plbl2';lbl.textContent=drum.label.split(' ')[0];

    // Knob state
    let knobVal=0; // -24 to +24
    let dragStartY=0,dragStartVal=0,isDragging=false;

    function drawKnob(val){
      const ctx2=cv.getContext('2d');
      const cx=size/2,cy=size/2,r=size/2-2;
      ctx2.clearRect(0,0,size,size);

      // Outer ring — groove/fender style
      const grad=ctx2.createRadialGradient(cx-r*.3,cy-r*.3,r*.05,cx,cy,r);
      grad.addColorStop(0,'#555');grad.addColorStop(.4,'#222');grad.addColorStop(1,'#111');
      ctx2.beginPath();ctx2.arc(cx,cy,r,0,Math.PI*2);ctx2.fillStyle=grad;ctx2.fill();

      // Rubber grip ring (dark notched ring)
      ctx2.beginPath();ctx2.arc(cx,cy,r,0,Math.PI*2);
      ctx2.strokeStyle='#1a1a1a';ctx2.lineWidth=r*.18;ctx2.stroke();

      // Knurled texture on grip
      for(let i=0;i<20;i++){
        const a=i*(Math.PI*2/20);
        const ri=r*.78,ro=r*.92;
        ctx2.beginPath();
        ctx2.moveTo(cx+Math.cos(a)*ri,cy+Math.sin(a)*ri);
        ctx2.lineTo(cx+Math.cos(a)*ro,cy+Math.sin(a)*ro);
        ctx2.strokeStyle='rgba(255,255,255,0.07)';ctx2.lineWidth=1.2;ctx2.stroke();
      }

      // Inner cap — dome
      const capGrad=ctx2.createRadialGradient(cx-r*.2,cy-r*.22,r*.08,cx,cy,r*.65);
      capGrad.addColorStop(0,'#4a4a4a');
      capGrad.addColorStop(.5,'#1e1e1e');
      capGrad.addColorStop(1,'#0d0d0d');
      ctx2.beginPath();ctx2.arc(cx,cy,r*.7,0,Math.PI*2);ctx2.fillStyle=capGrad;ctx2.fill();

      // Specular highlight
      ctx2.beginPath();ctx2.arc(cx-r*.18,cy-r*.2,r*.18,0,Math.PI*2);
      ctx2.fillStyle='rgba(255,255,255,0.07)';ctx2.fill();

      // Indicator line — color matches drum, rotates with value
      const minAng=Math.PI*0.75, maxAng=Math.PI*2.25;
      const ang=minAng+(val+24)/48*(maxAng-minAng);
      const r1=r*.35,r2=r*.65;
      ctx2.beginPath();
      ctx2.moveTo(cx+Math.cos(ang)*r1,cy+Math.sin(ang)*r1);
      ctx2.lineTo(cx+Math.cos(ang)*r2,cy+Math.sin(ang)*r2);
      ctx2.strokeStyle=val===0?'#888':val>0?'#c9900a':'#1a6eb5';
      ctx2.lineWidth=Math.max(1.5,size*.04);ctx2.lineCap='round';ctx2.stroke();

      // Arc track
      ctx2.beginPath();ctx2.arc(cx,cy,r*.82,minAng,maxAng);
      ctx2.strokeStyle='#2a2a2a';ctx2.lineWidth=2.5;ctx2.stroke();
      // Value arc
      if(val!==0){
        const midAng=minAng+(maxAng-minAng)/2;
        ctx2.beginPath();ctx2.arc(cx,cy,r*.82,val>0?midAng:ang,val>0?ang:midAng);
        ctx2.strokeStyle=val>0?'#c9900a66':'#1a6eb566';ctx2.lineWidth=2.5;ctx2.stroke();
      }
    }

    function setKnobVal(v){
      knobVal=Math.max(-24,Math.min(24,Math.round(v)));
      pitchMult[drum.id]=Math.pow(2,knobVal/12);
      valEl.textContent=(knobVal>0?'+':'')+knobVal;
      valEl.style.color=knobVal===0?'#444':knobVal>0?'#c9900a':'#1a6eb5';
      drawKnob(knobVal);
    }

    // Mouse drag
    wrap.addEventListener('mousedown',e=>{isDragging=true;dragStartY=e.clientY;dragStartVal=knobVal;e.preventDefault();});
    window.addEventListener('mousemove',e=>{if(!isDragging)return;const dy=dragStartY-e.clientY;setKnobVal(dragStartVal+Math.round(dy/3));});
    window.addEventListener('mouseup',()=>isDragging=false);
    // Touch drag
    wrap.addEventListener('touchstart',e=>{isDragging=true;dragStartY=e.touches[0].clientY;dragStartVal=knobVal;e.preventDefault();},{passive:false});
    wrap.addEventListener('touchmove',e=>{if(!isDragging)return;const dy=dragStartY-e.touches[0].clientY;setKnobVal(dragStartVal+Math.round(dy/3));e.preventDefault();},{passive:false});
    wrap.addEventListener('touchend',()=>isDragging=false);
    // Double-click reset
    wrap.addEventListener('dblclick',()=>setKnobVal(0));

    cell.appendChild(wrap);
    cell.appendChild(valEl);
    cell.appendChild(lbl);
    pr.appendChild(cell);
    drawKnob(0);
  });

  // PADS — pad-col : mute-top + pad carré
  const zone=document.getElementById('pads-zone');
  DRUMS.forEach(drum=>{
    const col=document.createElement('div');col.className='pad-col';
    const mb=document.createElement('button');
    mb.className='mute-top';mb.id='padmute-'+drum.id;mb.textContent='ON';
    mb.addEventListener('click',e=>{e.stopPropagation();toggleMute(drum.id);});
    const pad=document.createElement('div');pad.className='pad';pad.id='pd-'+drum.id;
    const led=document.createElement('div');led.className='pled';led.style.background=drum.color+'40';
    const lbl=document.createElement('div');lbl.className='plbl';lbl.textContent=drum.label;
    pad.appendChild(led);pad.appendChild(lbl);
    pad.addEventListener('mousedown',e=>{e.preventDefault();hitPad(drum);});
    pad.addEventListener('touchstart',e=>{e.preventDefault();hitPad(drum);},{passive:false});
    col.appendChild(mb);col.appendChild(pad);zone.appendChild(col);
  });

  buildVU();
  vuFrame();

  applySteps();
}

function applySteps(){
  // sync spacer width with dlbl width
  const sp=document.getElementById('shdr-sp');
  const dlbl0=document.querySelector('.dlbl');
  if(sp&&dlbl0) sp.style.width=dlbl0.offsetWidth+'px';
  for(let i=0;i<MAX_STEPS;i++){
    const show=i<STEPS;
    const hd=document.getElementById('sh'+i);
    if(hd){hd.style.display=show?'':'none';hd.textContent=i%4===0?(i/4+1):'·';}
    DRUMS.forEach(drum=>{
      const b=document.getElementById('sb-'+drum.id+'-'+i);
      if(b){
        b.style.display=show?'':'none';
        b.style.marginRight=(show&&i%4===3&&i<STEPS-1)?'clamp(2px,.35vw,5px)':'1px';
      }
    });
  }
  // re-run after layout
  requestAnimationFrame(()=>{
    const sp2=document.getElementById('shdr-sp');
    const dlbl2=document.querySelector('.dlbl');
    if(sp2&&dlbl2) sp2.style.width=dlbl2.offsetWidth+'px';
  });
}

