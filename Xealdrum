<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Xeal-Drum by David Alexandre</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@900&display=swap');

*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{width:100%;height:100%;overflow:hidden;touch-action:manipulation;font-family:'Courier New',monospace;}
body{background:#0d0d0d!important;transition:background .7s;}

/* ═══ LAYOUT ROOT ═══ */
#app{background:#141414;
  display:grid;
  width:100vw;height:100vh;
  grid-template-rows:auto auto 1fr auto auto;
  grid-template-columns:1fr;
  gap:0;
  padding:clamp(4px,1vmin,10px);
  row-gap:clamp(2px,.5vh,6px);
}

/* ═══ ROW 1 — TOPBAR ═══ */
#topbar{
  display:flex;align-items:center;
  justify-content:space-between;
  gap:8px;flex-wrap:nowrap;min-height:0;
}
.brand{display:flex;flex-direction:column;gap:1px;flex-shrink:0;}
#topbar-right{display:flex;align-items:center;gap:5px;flex-shrink:0;}
/* VU block */
#vu-block{background:#0a0a08;border:1px solid #2a2a1a;border-radius:6px;
  padding:3px 4px;box-shadow:inset 0 2px 6px rgba(0,0,0,.8);}
#vu-row{display:flex;align-items:stretch;gap:3px;}
#vu-l,#vu-r{display:block;width:clamp(48px,5.8vw,82px);height:clamp(36px,4.8vh,64px);
  flex-shrink:0;cursor:default;}
#vu-logo-c{display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:0 3px;min-width:clamp(30px,3.6vw,50px);}
#logo-img{width:clamp(20px,2.6vw,38px);height:clamp(20px,2.6vw,38px);
  object-fit:contain;pointer-events:none;
  filter:brightness(0) invert(1) sepia(1) hue-rotate(260deg) saturate(3) brightness(1.4)
    drop-shadow(0 0 4px rgba(255,45,190,.8));
  animation:logoshine 3s ease-in-out infinite;}
@keyframes logoshine{
  0%,100%{filter:brightness(0) invert(1) sepia(1) hue-rotate(260deg) saturate(3) brightness(1.4) drop-shadow(0 0 4px rgba(255,45,190,.8));}
  33%{filter:brightness(0) invert(1) sepia(1) hue-rotate(20deg) saturate(4) brightness(1.5) drop-shadow(0 0 6px rgba(232,64,26,1));}
  66%{filter:brightness(0) invert(1) sepia(1) hue-rotate(200deg) saturate(3.5) brightness(1.3) drop-shadow(0 0 6px rgba(100,80,255,.9));}
}
#xdlbl{font-family:'Orbitron',sans-serif;font-weight:900;font-size:clamp(5px,.75vw,9px);
  letter-spacing:.14em;margin-top:2px;white-space:nowrap;
  background:linear-gradient(180deg,#fff 0%,#ff9aee 18%,#ff2dbe 36%,#e8401a 52%,#c9900a 68%,#9a1aff 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 3px rgba(255,45,190,.5));animation:np 3s ease-in-out infinite;}
#xdby{color:#222;font-size:clamp(4px,.36vw,5px);letter-spacing:.1em;margin-top:1px;white-space:nowrap;}
.brand-name{
  font-family:'Orbitron',sans-serif;font-weight:900;
  font-size:clamp(13px,3.2vw,38px);
  letter-spacing:.18em;line-height:1;white-space:nowrap;
  background:linear-gradient(180deg,#fff 0%,#ffaaee 15%,#ff2dbe 32%,#e8401a 50%,#c9900a 66%,#ff2dbe 82%,#9a1aff 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 8px rgba(255,45,190,.7)) drop-shadow(0 0 20px rgba(232,64,26,.45));
  animation:np 3s ease-in-out infinite;
}
@keyframes np{
  0%,100%{filter:drop-shadow(0 0 6px rgba(255,45,190,.6)) drop-shadow(0 0 14px rgba(232,64,26,.4));}
  50%{filter:drop-shadow(0 0 14px rgba(255,45,190,1)) drop-shadow(0 0 30px rgba(232,64,26,.75)) drop-shadow(0 0 50px rgba(154,26,255,.5));}
}
.brand-sub{color:#2e2e2e;font-size:clamp(5px,.6vw,7px);letter-spacing:.22em;white-space:nowrap;}
.brand-by{
  font-size:clamp(5px,.6vw,7px);letter-spacing:.16em;white-space:nowrap;
  background:linear-gradient(90deg,#ff2dbe,#c9900a,#9a1aff);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

#lcd{
  background:#060e06;border:2px solid #142014;border-radius:4px;
  padding:clamp(4px,.6vh,8px) clamp(10px,1.4vw,20px);
  box-shadow:inset 0 2px 8px rgba(0,0,0,.95),0 0 10px rgba(0,255,65,.05);
  flex-shrink:0;text-align:center;
  min-width:clamp(130px,16vw,220px);
}
#lcd-text{
  color:#00ff41;font-family:'Courier New',monospace;font-weight:700;
  font-size:clamp(9px,1.2vw,16px);letter-spacing:.18em;
  text-shadow:0 0 10px rgba(0,255,65,1),0 0 22px rgba(0,255,65,.5);
  white-space:nowrap;
}

/* ═══ ROW 2 — CONTROLS ═══ */
#ctrl{
  display:flex;align-items:flex-end;
  gap:clamp(5px,.8vw,12px);flex-wrap:nowrap;
  overflow-x:auto;overflow-y:visible;
  scrollbar-width:none;min-height:0;
  padding-bottom:2px;
}
#ctrl::-webkit-scrollbar{display:none;}
.cg{display:flex;flex-direction:column;align-items:flex-start;gap:2px;flex-shrink:0;}
.cl{color:#3a3a3a;font-size:clamp(5px,.58vw,7px);letter-spacing:.18em;white-space:nowrap;text-transform:uppercase;}

/* Transport buttons */
.btn{
  padding:clamp(5px,.65vh,9px) clamp(8px,1vw,16px);
  border-radius:6px;font-family:'Courier New',monospace;
  font-size:clamp(8px,.9vw,13px);font-weight:700;
  letter-spacing:.12em;cursor:pointer;white-space:nowrap;
  border:2px solid #444;
  background:linear-gradient(180deg,#2a2a2a,#181818);color:#999;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.07),inset 0 -2px 0 rgba(0,0,0,.5),0 2px 6px rgba(0,0,0,.4);
  transition:transform .07s,box-shadow .07s;user-select:none;
}
.btn:active{transform:translateY(2px);box-shadow:inset 0 2px 0 rgba(0,0,0,.4);}
#btn-play{border-color:#1a7a1a;background:linear-gradient(180deg,#1a4a1a,#0a2a0a);color:#44ff44;text-shadow:0 0 8px rgba(0,255,0,.6);}
#btn-play.pon{background:linear-gradient(180deg,#bb2000,#7a1000);border-color:#ff4422;color:#fff;text-shadow:0 0 8px rgba(255,80,40,.8);box-shadow:0 0 14px rgba(200,30,0,.5);}
#btn-rec{border-color:#5a1515;background:linear-gradient(180deg,#2a0e0e,#160606);color:#cc4444;}
#btn-rec.ron{background:linear-gradient(180deg,#bb0000,#6a0000);border-color:#ff0000;color:#fff;text-shadow:0 0 8px #f88;animation:rp .9s infinite;}
@keyframes rp{0%,100%{box-shadow:0 0 8px rgba(255,0,0,.4);}50%{box-shadow:0 0 22px rgba(255,0,0,.9);}}
.btn.clr{border-color:#5a2008;color:#ff6622;background:linear-gradient(180deg,#281408,#140804);}
.btn.sav{color:#ffbb22;border-color:#4a3808;background:linear-gradient(180deg,#221a04,#100e02);}
#rec-dot{width:7px;height:7px;border-radius:50%;background:#f00;display:none;box-shadow:0 0 8px #f00;animation:rp .9s infinite;flex-shrink:0;margin-left:2px;}
#rec-dot.show{display:inline-block;}

/* Knobs */
.knob-wrap{cursor:pointer;touch-action:none;user-select:none;-webkit-user-select:none;}
.bnum{
  background:#060e06;border:1px solid #142014;border-radius:3px;
  color:#00ff41;font-family:'Courier New',monospace;
  font-size:clamp(7px,.8vw,11px);padding:2px 4px;
  text-shadow:0 0 5px rgba(0,255,65,.7);
  min-width:2.8em;text-align:center;font-weight:700;
}

select{
  background:#111;border:1px solid #333;border-radius:4px;
  color:#888;font-family:'Courier New',monospace;
  font-size:clamp(6px,.65vw,9px);padding:3px 4px;
  cursor:pointer;outline:none;
  max-width:clamp(90px,11vw,160px);
}

/* ═══ ROW 3 — SEQUENCER ═══ */
#seq{
  background:#080808;border-radius:6px;border:1px solid #1c1c1c;
  padding:clamp(3px,.5vh,6px) clamp(4px,.5vw,8px);
  display:flex;flex-direction:column;gap:0;
  box-shadow:inset 0 2px 10px rgba(0,0,0,.7);
  min-height:0;overflow:hidden;
}
#seq-hdr{display:flex;margin-bottom:1px;flex-shrink:0;}
.shdr-spacer{flex-shrink:0;}
.sn{flex:1;text-align:center;color:#282828;font-size:clamp(4px,.46vw,6.5px);}
.sn.b{color:#444;}
#seq-rows{display:flex;flex-direction:column;flex:1;min-height:0;gap:1px;}
.drow{display:flex;align-items:center;flex:1;min-height:0;}

/* Label + mute in seq */
.dlbl{
  display:flex;align-items:center;justify-content:flex-end;
  gap:clamp(2px,.3vw,5px);padding-right:clamp(2px,.3vw,5px);
  flex-shrink:0;
}
.dlbl-name{
  font-size:clamp(5.5px,.65vw,9px);font-weight:800;
  letter-spacing:.08em;white-space:nowrap;text-transform:uppercase;
  background:linear-gradient(180deg,#ddd 0%,#fff 25%,#bbb 55%,#888 78%,#ccc 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 1px 2px rgba(0,0,0,.9));
}
.mute-btn{
  width:clamp(12px,1.4vw,18px);height:clamp(12px,1.4vw,18px);
  border-radius:50%;cursor:pointer;flex-shrink:0;padding:0;
  border:2px solid #2a7a2a;
  background:radial-gradient(circle at 40% 38%,#2a5a2a,#0d1a0d);
  box-shadow:0 0 4px rgba(0,180,0,.3);
  transition:all .15s;position:relative;
}
.mute-btn::after{content:'';position:absolute;inset:3px;border-radius:50%;background:radial-gradient(circle at 40% 35%,rgba(0,255,80,.3),transparent 70%);pointer-events:none;}
.mute-btn.muted{border-color:#9a1a1a;background:radial-gradient(circle at 40% 38%,#bb1e00,#5a0800);box-shadow:0 0 8px rgba(220,50,20,.6);}
.mute-btn.muted::after{background:radial-gradient(circle at 40% 35%,rgba(255,100,60,.35),transparent 70%);}
.drow.muted .sb.on{opacity:.18;}
.drow.muted .sb.cur{opacity:.28!important;}

/* Step buttons */
.sb{
  flex:1;height:100%;min-height:0;
  background:#161616;border:1px solid #1c1c1c;
  border-radius:2px;cursor:pointer;
  transition:background .04s;margin:1px;padding:0;
}
.sb.bst{background:#1a1a1a;border-color:#222;}
.sb.gsep{margin-right:clamp(2px,.32vw,5px);}
.sb.on{box-shadow:0 0 4px currentColor;}
.sb.cur:not(.on){background:rgba(255,255,255,.18)!important;border-color:rgba(255,255,255,.28)!important;}
.sb.on.cur{background:#fff!important;border-color:#fff!important;box-shadow:0 0 8px rgba(255,255,255,.7)!important;}

/* ═══ ROW 4 — PITCH KNOBS ═══ */
#pitch-row{
  display:flex;gap:clamp(3px,.4vw,6px);
  flex-shrink:0;
  align-items:flex-end;
}
.pcell{flex:1;display:flex;flex-direction:column;align-items:center;gap:1px;}
.pcell-knob-wrap{cursor:pointer;touch-action:none;user-select:none;-webkit-user-select:none;}
.pval{color:#444;font-size:clamp(4px,.42vw,6px);font-family:'Courier New',monospace;text-align:center;}
.plbl2{color:#3a3a3a;font-size:clamp(4px,.42vw,6px);letter-spacing:.05em;text-align:center;white-space:nowrap;text-transform:uppercase;}

/* ═══ ROW 5 — PADS + MUTE BAR ═══ */
/* ═══ PADS ZONE — colonnes ═══ */
#pads-zone{display:flex;gap:clamp(3px,.4vw,6px);flex-shrink:0;}
.pad-col{flex:1;min-width:0;display:flex;flex-direction:column;
  align-items:stretch;gap:clamp(2px,.28vh,3px);}
.mute-top{
  width:100%;height:clamp(12px,1.7vh,20px);
  border-radius:4px;cursor:pointer;padding:0;
  border:2px solid #1a6a1a;
  background:radial-gradient(ellipse at 50% 35%,#1a4a1a,#080e08);
  font-family:'Courier New',monospace;
  font-size:clamp(5px,.55vw,7.5px);font-weight:800;
  color:#22cc22;letter-spacing:.05em;
  box-shadow:0 0 4px rgba(0,180,0,.15);
  transition:background .12s,border-color .12s,color .12s;
}
.mute-top.muted{
  border-color:#8a1010;
  background:radial-gradient(ellipse at 50% 35%,#bb1c00,#580600);
  color:#ff8855;box-shadow:0 0 7px rgba(190,30,0,.45);
}
.pad{
  width:100%;aspect-ratio:1/1;max-height:clamp(44px,10.5vh,90px);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:clamp(1px,.2vh,3px);border-radius:5px;cursor:pointer;
  border:2px solid #252525;background:linear-gradient(155deg,#202020,#111);
  box-shadow:inset 0 -3px 0 rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.04);
  transition:all .06s;user-select:none;-webkit-user-select:none;
  position:relative;overflow:hidden;
}
.pad::before{content:'';position:absolute;inset:0;background:linear-gradient(155deg,rgba(255,255,255,.04),transparent 55%);pointer-events:none;}
.pad.hit{transform:translateY(2px);box-shadow:inset 0 -1px 0 rgba(0,0,0,.5);}
.pled{width:clamp(4px,.55vw,8px);height:clamp(4px,.55vw,8px);border-radius:50%;flex-shrink:0;transition:all .06s;}
.plbl{
  font-size:clamp(4.5px,.55vw,7.5px);font-weight:700;
  letter-spacing:.06em;text-align:center;line-height:1;
  text-transform:uppercase;transition:color .06s;
  background:linear-gradient(180deg,#ccc,#888);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.pad.hit .plbl{background:none;-webkit-text-fill-color:#fff;}

/* ═══ FOOTER ═══ */
#footer{
  display:flex;align-items:center;justify-content:space-between;
  flex-shrink:0;padding:0 2px;
}
.ftxt{color:#1e1e1e;font-size:clamp(4px,.44vw,6px);letter-spacing:.1em;}
#vu-wrap{display:flex;align-items:flex-end;gap:2px;height:20px;}
.vub{border-radius:1px;background:#1a1a1a;position:relative;overflow:hidden;}
.vub-fill{position:absolute;bottom:0;left:0;right:0;border-radius:1px;transition:height .06s ease-out;}

/* ═══ SAVE MODAL ═══ */
#save-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:100;align-items:center;justify-content:center;}
#save-modal.show{display:flex;}
#save-box{background:#181818;border:1px solid #3a3a3a;border-radius:8px;padding:18px 22px;display:flex;flex-direction:column;gap:10px;min-width:260px;}
#save-box h3{color:#c9900a;font-size:12px;letter-spacing:.2em;}
#save-name{background:#0e0e0e;border:1px solid #3a3a3a;border-radius:4px;color:#ccc;font-family:'Courier New',monospace;font-size:12px;padding:6px 10px;outline:none;width:100%;}
#save-name:focus{border-color:#555;}
.mbts{display:flex;gap:8px;}
.mbts .btn{flex:1;text-align:center;}

/* ═══ RESPONSIVE ═══ */
@media(max-width:540px){
  #topbar{flex-wrap:wrap;}
  #ctrl{flex-wrap:wrap;overflow-x:hidden;}
  .brand-name{font-size:clamp(14px,6vw,26px);}
}
</style>
</head>
<body>
<div id="app">

    <!-- ROW 1 : TOPBAR -->
  <div id="topbar">
    <div class="brand">
      <div class="brand-name">XEAL-DRUM</div>
      <div class="brand-sub">UNIVERSAL DRUM COMPUTER — ALL ERAS</div>
      <div class="brand-by">by David Alexandre</div>
    </div>
    <div id="lcd"><div id="lcd-text">XEAL-DRUM  READY</div></div>
    <div id="topbar-right">
      <div id="rec-dot"></div>
      <div id="vu-block">
        <div id="vu-row">
          <canvas id="vu-l" title="L"></canvas>
          <div id="vu-logo-c">
            <img id="logo-img" src="data:image/png;base64," alt="logo" draggable="false">
            <div id="xdlbl">X-DRUM</div>
            <div id="xdby">by David Alexandre</div>
          </div>
          <canvas id="vu-r" title="R"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- ROW 2 : CONTROLS -->
  <div id="ctrl">
    <!-- Transport -->
    <div class="cg">
      <div class="cl">TRANSPORT</div>
      <div style="display:flex;gap:4px;align-items:center;">
        <button class="btn" id="btn-play" onclick="togglePlay()">▶ PLAY</button>
        <button class="btn" id="btn-rec" onclick="toggleRec()">⏺ REC</button>
        <button class="btn clr" onclick="clearPat()">CLR</button>
      </div>
    </div>
    <!-- TEMPO knob -->
    <div class="cg">
      <div class="cl">TEMPO</div>
      <div style="display:flex;align-items:center;gap:5px;">
        <div class="knob-wrap" id="knob-bpm-wrap"><canvas id="knob-bpm" width="44" height="44"></canvas></div>
        <div class="bnum" id="bpm-num">110</div>
      </div>
    </div>
    <!-- VOLUME knob -->
    <div class="cg">
      <div class="cl">VOLUME</div>
      <div class="knob-wrap" id="knob-vol-wrap"><canvas id="knob-vol" width="44" height="44"></canvas></div>
    </div>
    <!-- SWING knob -->
    <div class="cg">
      <div class="cl">SWING</div>
      <div class="knob-wrap" id="knob-sw-wrap"><canvas id="knob-sw" width="44" height="44"></canvas></div>
    </div>
    <!-- MACHINE -->
    <div class="cg">
      <div class="cl">MACHINE</div>
      <select id="mach-sel" onchange="loadMachine(this.value)">
        <option value="LINNDRUM">LinnDrum LM-2 (1982)</option>
        <option value="TR808">Roland TR-808 (1980)</option>
        <option value="TR909">Roland TR-909 (1983)</option>
        <option value="DMX">Oberheim DMX (1981)</option>
        <option value="TR606">Roland TR-606 (1982)</option>
        <option value="CR78">Roland CR-78 (1978)</option>
        <option value="MINIPOP7">Korg MiniPop 7 (1967)</option>
        <option value="TR707">Roland TR-707 (1984)</option>
        <option value="SP1200">E-mu SP-1200 (1987)</option>
        <option value="MPC60">Akai MPC60 (1988)</option>
        <option value="DRUMTRAKS">Sequential Drumtraks (1984)</option>
        <option value="R8">Roland R-8 (1989)</option>
        <option value="MPC3000">Akai MPC3000 (1994)</option>
        <option value="RYTM">Elektron Rytm (2014)</option>
        <option value="MODULAR">Modular / Eurorack</option>
        <option value="TRAP808">Trap 808 Modern</option>
      </select>
    </div>
    <!-- GROOVE -->
    <div class="cg">
      <div class="cl">GROOVE</div>
      <div style="display:flex;gap:4px;align-items:center;">
        <select id="grv-sel" onchange="loadGroove()">
          <optgroup label="── 1970s ──">
            <option value="DISCO70">Disco 70s</option>
            <option value="FUNK70">Funk 70s</option>
            <option value="SOUL70">Soul / R&amp;B 70s</option>
          </optgroup>
          <optgroup label="── 1980s ──">
            <option value="NEWWAVE">New Wave 80s</option>
            <option value="HIPHOP80">Hip Hop 80s</option>
            <option value="POPROCK">Pop Rock 80s</option>
            <option value="ELECTRO80">Electro 80s</option>
            <option value="SYNPOP">Synth Pop 80s</option>
          </optgroup>
          <optgroup label="── 1990s ──">
            <option value="HOUSE">House Chicago</option>
            <option value="TECHNO">Techno Detroit</option>
            <option value="JUNGLE">Jungle / DnB</option>
            <option value="HIPHOP90">Hip Hop 90s</option>
            <option value="RAVE">Rave / Hardcore</option>
            <option value="RNB90">R&amp;B Neo Soul 90s</option>
          </optgroup>
          <optgroup label="── 2000s ──">
            <option value="GARAGE">UK Garage</option>
            <option value="CRUNK">Crunk / Snap</option>
            <option value="ELECTROHOUSE">Electro House</option>
          </optgroup>
          <optgroup label="── 2010s ──">
            <option value="TRAP">Trap 2010s</option>
            <option value="FUTURE">Future Bass</option>
            <option value="AFROBEAT">Afrobeat</option>
            <option value="DEEPHOUSE">Deep House</option>
          </optgroup>
          <optgroup label="── 2020s ──">
            <option value="AFROTRAP">Afrotrap</option>
            <option value="DRILL">Drill UK / NY</option>
            <option value="AMAPIANO">Amapiano</option>
            <option value="HYPERPOP">Hyperpop</option>
          </optgroup>
          <optgroup label="── Distinctifs ──">
            <option value="BOSSANOVA">Bossa Nova</option>
            <option value="SAMBA">Samba</option>
            <option value="HALFSTEP">Half-Step</option>
            <option value="BREAKBEAT">Breakbeat</option>
            <option value="REGGAETON">Reggaeton</option>
            <option value="CUMBIA">Cumbia</option>
            <option value="FOOTWORK">Footwork / Juke</option>
            <option value="WALTZ">Valse / Waltz</option>
          </optgroup>
          <optgroup label="── Jean-Michel Jarre ──">
            <option value="JMJ_OXY4">Oxygène Pt.4 (1976)</option>
            <option value="JMJ_OXY2">Oxygène Pt.2 (1976)</option>
            <option value="JMJ_EQX4">Équinoxe Pt.4 (1978)</option>
