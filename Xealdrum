const ep=()=>{const p={};DRUMS.forEach(d=>p[d.id]=new Array(MAX_STEPS).fill(false));return p;};

// Scale a 16-step pattern to target length
function scalePattern(src16,target){
  if(target===16)return src16;
  const out=new Array(MAX_STEPS).fill(false);
  for(let i=0;i<target;i++){
    const orig=Math.round(i*16/target);
    out[i]=src16[Math.min(orig,15)];
  }
  return out;
}
function ep16(){return new Array(16).fill(false);}

function makeGroove(fn){
  return ()=>{
    const base=fn(); // base is MAX_STEPS long, pattern defined on first 16 steps
    // Tile the 16-step core across all 32 slots so any STEPS length has content
    const tiled={};
    DRUMS.forEach(d=>{
      tiled[d.id]=new Array(MAX_STEPS).fill(false);
      for(let i=0;i<MAX_STEPS;i++){
        tiled[d.id][i]=base[d.id][i%16]; // repeat the 16-step pattern
      }
    });
    return tiled;
  };
}

